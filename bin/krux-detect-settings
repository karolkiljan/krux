#!/usr/bin/env node
// krux — detect which settings.json has krux enabled.
// Prints path of project .claude/settings.json if it lists krux in enabledPlugins,
// otherwise falls back to ~/.claude/settings.json.

const fs = require('fs');
const path = require('path');
const os = require('os');

const projectSettings = path.join(process.cwd(), '.claude', 'settings.json');

if (fs.existsSync(projectSettings)) {
  try {
    const data = JSON.parse(fs.readFileSync(projectSettings, 'utf8'));
    const plugins = data.enabledPlugins || {};
    if (Object.entries(plugins).some(([key, enabled]) => key.includes('krux') && enabled === true)) {
      process.stdout.write(projectSettings);
      process.exit(0);
    }
  } catch (e) {}
}

process.stdout.write(path.join(os.homedir(), '.claude', 'settings.json'));
